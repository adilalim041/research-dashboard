# ── Server-only (set in Vercel project settings, NEVER prefix with VITE_) ──────

# GitHub Personal Access Token — scope: repo (or public_repo if vault is public)
# Used server-side only in api/promote.ts to read/write ObsidianVault repo.
# NEVER expose as VITE_GITHUB_PAT — it would be bundled into the client JS.
GITHUB_PAT=ghp_...

# Admin secret for POST /api/promote — must be 32+ chars random string.
# Generate: openssl rand -base64 32
# NEVER expose as VITE_ADMIN_SECRET — it would be bundled into the client JS.
ADMIN_SECRET=...

# Allowed CORS origin for the /api/* endpoints.
# In production: set to the exact Vercel deployment URL.
# If unset, defaults to * (dev-only, insecure for production).
DASHBOARD_ORIGIN=https://research-dashboard-eight.vercel.app

# Set to "true" to skip all GitHub writes (useful for local testing).
# api/promote will return 201 with a fake id without touching the vault.
DRY_RUN=false

# ── Client-side (VITE_*, safe to bundle — read-only, rate-limit bump only) ────

# Optional: Raises GitHub anonymous rate limit from 60/h to 5000/h.
# This is a READ-ONLY token for the client dashboard to list/read vault files.
# Must NOT have write permissions. Scope: public_repo (read-only) is sufficient.
VITE_GITHUB_TOKEN=ghp_...
